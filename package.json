{
  "name": "fakeagent",
  "version": "0.0.0",
  "description": "Fake API server for testing tools that use coding agent CLIs",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "pnpm build",
    "test": "vitest run"
  },
  "keywords": ["testing", "agent", "cli", "claude", "codex", "opencode", "fake", "mock"],
  "author": "mmkal",
  "license": "ISC",
  "packageManager": "pnpm@10.30.1",
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "typescript": "^6.0.2",
    "vitest": "4.1.1"
  },
  "dependencies": {
    "ws": "^8.20.0"
  }
}
